<!-- @format -->

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>New Reply Notification</title>
  </head>
  <body
    style="
      margin: 0;
      padding: 0;
      background: #f4f7fb;
      font-family: Arial, Helvetica, sans-serif;
    "
  >
    <table width="100%" cellpadding="0" cellspacing="0">
      <tr>
        <td align="center" style="padding: 40px 20px">
          <table
            width="600"
            cellpadding="0"
            cellspacing="0"
            style="
              background: #ffffff;
              border-radius: 12px;
              overflow: hidden;
              box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            "
          >
            <tr>
              <td
                align="center"
                style="background: #2563eb; padding: 30px; color: #ffffff"
              >
                <h1 style="margin: 0; font-size: 28px">
                  New Reply Received 💬
                </h1>
              </td>
            </tr>

            <tr>
              <td style="padding: 40px 30px; color: #333333">
                <h2 style="margin-top: 0">Hello <%= name %>,</h2>

                <p style="font-size: 16px; line-height: 1.7">
                  Great news! Someone has replied to your question in:
                </p>

                <div
                  style="
                    background: #f8fafc;
                    border-left: 4px solid #2563eb;
                    padding: 15px;
                    margin: 20px 0;
                    border-radius: 6px;
                  "
                >
                  <strong><%= title %></strong>
                </div>

                <p style="font-size: 16px; line-height: 1.7">
                  Log in to your account to view the reply and continue the
                  discussion with other learners.
                </p>

                <p style="font-size: 14px; color: #666; line-height: 1.6">
                  Thank you for being part of our learning community. We’re
                  excited to help you grow and learn every day.
                </p>

                <hr
                  style="
                    border: none;
                    border-top: 1px solid #e5e7eb;
                    margin: 30px 0;
                  "
                />

                <p style="font-size: 12px; color: #9ca3af; text-align: center">
                  © <%= new Date().getFullYear() %> LMS Platform. All rights
                  reserved.
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
