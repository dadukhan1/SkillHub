<!-- @format -->

<!-- Order Summary -->
<table
  width="100%"
  cellpadding="10"
  cellspacing="0"
  style="margin-top: 20px; border-top: 1px solid #e5e7eb"
>
  <tr>
    <td align="right" style="color: #6b7280">Subtotal:</td>
    <td align="right" style="font-weight: bold; color: #111827; width: 120px">
      $<%= order.price %>
    </td>
  </tr>

  <tr>
    <td
      align="right"
      style="font-size: 20px; font-weight: bold; color: #111827"
    >
      Total:
    </td>
    <td
      align="right"
      style="font-size: 20px; font-weight: bold; color: #2563eb"
    >
      $<%= order.price %>
    </td>
  </tr>
</table>

<!-- Support Section -->
<div
  style="
    margin-top: 35px;
    padding: 20px;
    background: #f8fafc;
    border-radius: 10px;
    text-align: center;
  "
>
  <p style="margin: 0; color: #4b5563; line-height: 1.8">
    Need help with your purchase?
    <br />
    Contact our support team at
    <a
      href="mailto:support@yourlms.com"
      style="color: #2563eb; text-decoration: none; font-weight: bold"
    >
      support@yourlms.com
    </a>
  </p>
</div>
